import google.generativeai as genai
import time
from collections import deque

# ================= CONFIG =================
API_KEY = "AIzaSyCK5Jxfuq0aS38zcOK0CTkz52QW9p9txfY"
MODEL = "models/gemini-2.5-flash"

TOPIC = "Should AI models be open-source?"
ROUNDS = 6
MAX_SUMMARIES = 4
SLEEP_SECONDS = 1.2  # rate-limit safety

# =========================================

genai.configure(api_key=API_KEY)
model = genai.GenerativeModel(MODEL)

memory = deque(maxlen=MAX_SUMMARIES)
transcript = []

# ================= HELPERS =================

def context_block():
    if not memory:
        return "No prior discussion."
    return "\n".join(f"{i+1}. {m}" for i, m in enumerate(memory))


def agent_prompt(role, stance, last_msg):
    return f"""
You are an AI debater.

Topic:
{TOPIC}

Your role:
{role}

Your stance:
{stance}

Compressed discussion memory:
{context_block()}

Last message from opponent:
"{last_msg}"

Rules:
- No repetition
- Add new reasoning
- 4–6 sentences max
- Stay logical, not emotional
"""


def summarize(a, b):
    prompt = f"""
Summarize the following debate exchange in **exactly 2 short lines**.
Capture only key reasoning.

A: {a}
B: {b}
"""
    return model.generate_content(prompt).text.strip()


def generate(text):
    return model.generate_content(text).text.strip()


# ================= DEBATE =================

last_message = "Begin the debate with your strongest opening argument."

for round_no in range(1, ROUNDS + 1):
    print(f"\n===== ROUND {round_no} =====")

    # Agent A (PRO)
    a_prompt = agent_prompt("Agent A", "FOR the topic", last_message)
    a_reply = generate(a_prompt)
    print("\nAgent A:", a_reply)

    # Agent B (CON)
    b_prompt = agent_prompt("Agent B", "AGAINST the topic", a_reply)
    b_reply = generate(b_prompt)
    print("\nAgent B:", b_reply)

    transcript.append(("A", a_reply))
    transcript.append(("B", b_reply))

    # Summarize
    summary = summarize(a_reply, b_reply)
    memory.append(summary)

    print("\nSummary:", summary)

    last_message = b_reply
    time.sleep(SLEEP_SECONDS)

# ================= CONCLUSION =================

final_prompt = f"""
You are a neutral judge.

Topic:
{TOPIC}

Debate summaries:
{context_block()}

Task:
Write a balanced final conclusion.
- Mention strongest pro
- Mention strongest con
- Give a reasoned verdict
- 6–8 sentences
"""

final_conclusion = generate(final_prompt)

print("\n===== FINAL CONCLUSION =====\n")
print(final_conclusion)
